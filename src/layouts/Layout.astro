---
import '../styles/global.css';
import { Schema } from 'astro-seo-schema';
import content from '../data/content.json';
import { type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
  title?: string;
}

const { lang, title } = Astro.props;
const t = useTranslations(lang);

const { author, linkedin, github, photo } = content.about;

const BASE_URL = import.meta.env.MODE === 'production' ? '/portfolio-dev' : '';
const pageTitle = title ?? t('meta.title');
---

<!doctype html>
<html lang={lang === 'pt' ? 'pt-BR' : 'en'} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<title>{pageTitle}</title>
		<meta name="author" content={author} />
		<meta name="description" content={t('meta.description')} />
		<meta name="robots" content="index, follow" />
		<meta name="theme-color" content="#0a0e1a" />

		<link rel="icon" type="image/svg+xml" href={BASE_URL + '/favicon.svg'} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>

		<link rel="alternate" hreflang="en" href={`${Astro.site}portfolio-dev/en/`} />
		<link rel="alternate" hreflang="pt-BR" href={`${Astro.site}portfolio-dev/pt/`} />
		<link rel="canonical" href={`${Astro.site}portfolio-dev/${lang}/`} />

		<Schema
			item={{
				'@context': 'https://schema.org',
				'@type': 'Person',
				name: author,
				jobTitle: content.about.role,
				url: Astro.request.url,
				sameAs: [linkedin, github],
				image: `${Astro.site}portfolio-dev${photo}`,
			}}
		/>
	</head>
	<body class="bg-ink-950 text-paper antialiased selection:bg-copper-500 selection:text-ink-950">
		<div class="mx-auto max-w-5xl">
			<slot />
		</div>
	</body>
</html>
