---
import { languages, type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const otherLang: Lang = lang === 'en' ? 'pt' : 'en';
const BASE_URL = import.meta.env.MODE === 'production' ? '/portfolio-dev' : '';

const navLinks = [
  { href: '#about', label: t('nav.about') },
  { href: '#experience', label: t('nav.experience') },
  { href: '#projects', label: t('nav.projects') },
  { href: '#contact', label: t('nav.contact') },
];
---

<div class="pointer-events-none sticky top-0 z-20 flex justify-center px-4 pt-4">
	<header
		class="pointer-events-auto flex w-full max-w-2xl items-center justify-between gap-2 rounded-full border border-ink-700 bg-ink-900/80 px-3 py-2 shadow-lg shadow-black/30 backdrop-blur-md backdrop-saturate-150"
	>
		<a href={`${BASE_URL}/${lang}/`} class="shrink-0 rounded-full px-2 font-display text-sm font-semibold tracking-tight text-paper">
			Felipe Trombini
		</a>

		<nav class="hidden items-center gap-1 md:flex">
			{navLinks.map(({ href, label }) => (
				<a
					href={href}
					class="rounded-full px-3 py-1.5 font-mono text-xs uppercase tracking-wider text-paper-muted transition-colors duration-150 hover:bg-ink-700 hover:text-paper"
				>
					{label}
				</a>
			))}
			<a
				href={`${BASE_URL}/${otherLang}/`}
				class="ml-1 shrink-0 rounded-full border border-ink-600 px-3 py-1.5 font-mono text-xs uppercase tracking-wider text-paper-muted transition-colors duration-150 hover:border-copper-500 hover:text-copper-400"
			>
				{languages[otherLang]}
			</a>
		</nav>

		<details class="relative md:hidden">
			<summary
				class="cursor-pointer list-none rounded-full border border-ink-600 px-3 py-1.5 font-mono text-xs uppercase tracking-wider text-paper-muted"
			>
				Menu
			</summary>
			<div class="absolute right-0 top-full z-10 mt-2 w-52 rounded-2xl border border-ink-700 bg-ink-800 p-2 shadow-xl shadow-black/40">
				{navLinks.map(({ href, label }) => (
					<a
						href={href}
						class="block rounded-xl px-4 py-2 font-mono text-xs uppercase tracking-wider text-paper-muted hover:bg-ink-700 hover:text-paper"
					>
						{label}
					</a>
				))}
				<a
					href={`${BASE_URL}/${otherLang}/`}
					class="block rounded-xl px-4 py-2 font-mono text-xs uppercase tracking-wider text-copper-400 hover:bg-ink-700"
				>
					{languages[otherLang]}
				</a>
			</div>
		</details>
	</header>
</div>
